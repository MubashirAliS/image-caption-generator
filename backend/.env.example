# Backend environment (copy to .env and edit for production)
# Comma-separated list of allowed CORS origins. If your frontend is served on the same origin, you can set this to ""
CORS_ORIGINS=

# Optional: override model path if you place models elsewhere
# MODEL_PATH=/home/ubuntu/caption-app/backend/model/InceptionV3_best_model.keras
# TOKENIZER_PATH=/home/ubuntu/caption-app/backend/model/tokenizer.pkl
# MAX_LENGTH_PATH=/home/ubuntu/caption-app/backend/model/max_length.pkl

# Logging level
LOG_LEVEL=INFO
